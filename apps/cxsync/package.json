{
  "name": "@cxsun/cxsync",
  "private": true,
  "version": "1.0.125",
  "type": "module",
  "description": "CXSync super-admin database operations and analytics console",
  "author": "CODEXSUN",
  "main": "dist/electron/electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k --success first -n web,desktop \"npm run dev:web\" \"npm run dev:electron\"",
    "dev:web": "vite --port 6044",
    "dev:electron": "npm run compile:electron && node scripts/launch-electron.mjs",
    "compile:electron": "tsc -p tsconfig.electron.json && node scripts/write-preload-cjs.mjs",
    "build:web": "vite build",
    "build": "npm run build:web && npm run compile:electron && electron-builder",
    "build:dir": "npm run build:web && npm run compile:electron && electron-builder --dir",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@cxsun/app-shell": "*",
    "@cxsun/ui": "*",
    "lucide-react": "^1.14.0",
    "mysql2": "^3.22.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "37.10.3",
    "electron-builder": "^26.0.12",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.codexsun.cxsync",
    "productName": "CXSync",
    "asar": true,
    "directories": {
      "output": "../../build/cxsync-installer"
    },
    "files": [
      "dist/electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../build/apps/cxsync",
        "to": "frontend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
