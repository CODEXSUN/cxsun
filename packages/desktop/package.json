{
  "name": "@cxsun/desktop",
  "version": "1.0.128",
  "private": true,
  "type": "module",
  "description": "CXSun desktop application",
  "author": "CODEXSUN",
  "main": "dist/main/index.js",
  "scripts": {
    "compile": "tsc && node scripts/write-preload-cjs.mjs && node scripts/generate-icons.mjs",
    "dev": "npm run compile && electron .",
    "build": "npm -w @cxsun/frontend run build && npm run compile && electron-builder",
    "build:dir": "npm -w @cxsun/frontend run build && npm run compile && electron-builder --dir",
    "e2e": "npm -w @cxsun/frontend run build && npm run compile && node scripts/e2e-smoke.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.codexsun.desktop",
    "productName": "CXSun",
    "asar": true,
    "directories": {
      "output": "../../build/desktop"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../build/frontend",
        "to": "frontend"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
