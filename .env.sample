# ─── Server ──────────────────────────────────────────
PORT=6005
PLATFORM_API_PORT=6105
PLATFORM_API_PUBLIC_URL=http://localhost:6105

# Private CXSync Cloud service. Run separately from the client billing backend.
CXSYNC_CLOUD_PORT=6077
CXSYNC_CLOUD_HOST=0.0.0.0
CXSYNC_CLOUD_LOG_LEVEL=info
CXSYNC_CLOUD_PUBLIC_URL=https://cxsync.codexsun.com
CXSYNC_SERVICE_KEY=
CXSYNC_CLOUD_SKIP_PLATFORM_MIGRATIONS=false
CXSYNC_FLEET_CLONE_ENABLED=false
CXSYNC_FLEET_SOURCE_QUIESCED=false
CXSYNC_FLEET_DUMP_PATH=
CXSYNC_FLEET_CLIENT_PATH=
CXSYNC_EXPECTED_VERSION=1.0.128
CXSYNC_MAINTENANCE_WEB_HOST_PORT=6080
CXSYNC_MAINTENANCE_API_HOST_PORT=6078

# ─── Frontend ─────────────────────────────────────────
VITE_PORT=6010
DOCS_PORT=6020
VITE_API_BASE_URL=http://codexsun.local:6005
VITE_STORAGE_BASE_URL=http://codexsun.local:6005
VITE_MEDIA_MANAGER_URL=http://localhost:6050
DEVELOPER_MODE=false
FRONTEND_URL=http://codexsun.local:6010
CORS_ORIGINS=http://localhost:6010,https://localhost:6010,http://codexsun.local:6010,https://codexsun.local:6010

# Media container
CXMEDIA_PORT=6050
CXMEDIA_ADMIN_PASSWORD=Sundarcomputers@123
CXMEDIA_STORAGE_VOLUME=cxmedia-storage
CXMEDIA_DB_VOLUME=cxmedia-db

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cxsun_master
DB_USER=root
DB_PASSWORD=Computer.1
CXSYNC_DB_NAME=cxsync_admin
# Optional when MariaDB tools are not available on PATH or in a standard installation folder.
CXSYNC_MARIADB_DUMP_PATH=
CXSYNC_MARIADB_CLIENT_PATH=
CXSYNC_SCHEMA_BUILD_TIMEOUT_MS=600000

# Tirupur Connect owns a separate product database.
# Host/user/password fall back to DB_* when omitted.
TIRUPUR_CONNECT_DB_HOST=localhost
TIRUPUR_CONNECT_DB_PORT=3306
TIRUPUR_CONNECT_DB_NAME=tirupur_connect_db
TIRUPUR_CONNECT_DB_USER=root
TIRUPUR_CONNECT_DB_PASSWORD=
TIRUPUR_CONNECT_DB_CONNECTION_LIMIT=10

# ─── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ─── Queue / Workers ────────────────────────────────
QUEUE_ENABLED=true
DATABASE_BACKUP_INTERVAL_HOURS=6
INSTALL_RUN_TESTS=false
AUTO_SEED_TENANT_DOMAINS=false
SKIP_MARIADB_WAIT=true
HEALTH_WAIT_SECONDS=900
CLOUD_DOCS_ENABLED=true
CLOUD_PRODUCT_APPS=auditor:6030,ecommerce:6031,b2b-connect:6032,sports:6033,learning:6034,welfare:6035,crm:6036,sites:6037,blog:6038,zetro:6039,textile-lab:6040,garment:6041,upvc:6042,b2b-connect-admin:6043,cxsync:6044
CLOUD_CXSYNC_CLOUD_ENABLED=false

# Default/fallback mail settings. Tenants can override these from Mail Settings.
MAIL_ENABLED=false
MAIL_PROVIDER=smtp
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=
MAIL_REPLY_TO=
MAIL_SMTP_HOST=smtp.hostinger.com
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE=true
MAIL_IMAP_HOST=imap.hostinger.com
MAIL_IMAP_PORT=993
MAIL_POP3_HOST=pop.hostinger.com
MAIL_POP3_PORT=995

# Razorpay subscription collection.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_BASE_URL=https://api.razorpay.com/v1

# ─── JWT / Auth ──────────────────────────────────────
JWT_SECRET=                              # REQUIRED — no fallback

# Optional first platform users. Leave blank on live and create users manually
# unless this deployment intentionally needs a seeded owner account.
# Tirupur Connect central marketplace connector signing.
TIRUPUR_CONNECT_SYNC_SECRET=
TIRUPUR_CONNECT_SYNC_TOLERANCE_SECONDS=300
TIRUPUR_CONNECT_MEMBER_TOKEN_HOURS=168

SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SOFTWARE_ADMIN_NAME=
SOFTWARE_ADMIN_EMAIL=
SOFTWARE_ADMIN_PASSWORD=

# Optional tenant setup helper account. Leave blank on live unless you
# intentionally want every newly setup tenant to receive this admin user.
TENANT_ADMIN_NAME=
TENANT_ADMIN_EMAIL=
TENANT_ADMIN_PASSWORD=

# WhiteBooks GST / e-Invoice / e-Way GSP
# Credentials are managed in the app:
# - super-admin GST API stores base URL, registered email, client ID/secret, and IP.
# - tenant GST API stores username, password, and GSTIN per company/environment.
GSP_ENVIRONMENT=sandbox
GSP_SANDBOX_BASE_URL=https://apisandbox.whitebooks.in
GSP_BASE_URL=https://api.whitebooks.in

# ZETRO Agent OS
# Free models are listed first. Premium providers can be connected from the ZETRO panel or optional env keys.
ZETRO_PROVIDER=openrouter
ZETRO_DEFAULT_MODEL=nex-agi/nex-n2-pro:free
ZETRO_FREE_MODELS=nex-agi/nex-n2-pro:free,nvidia/nemotron-3-ultra-550b-a55b:free,nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free,poolside/laguna-xs.2:free,poolside/laguna-m.1:free,google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free,nvidia/nemotron-3-super-120b-a12b:free,liquid/lfm-2.5-1.2b-thinking:free,liquid/lfm-2.5-1.2b-instruct:free,nvidia/nemotron-3-nano-30b-a3b:free,nvidia/nemotron-nano-12b-v2-vl:free,qwen/qwen3-next-80b-a3b-instruct:free,nvidia/nemotron-nano-9b-v2:free,openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,qwen/qwen3-coder:free,cognitivecomputations/dolphin-mistral-24b-venice-edition:free,meta-llama/llama-3.3-70b-instruct:free,meta-llama/llama-3.2-3b-instruct:free,nousresearch/hermes-3-llama-3.1-405b:free,nvidia/nemotron-3.5-content-safety:free
ZETRO_PREMIUM_MODELS=openai/gpt-4.1,anthropic/claude-sonnet-4.5,google/gemini-2.5-pro
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=CXSun ZETRO
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_API_KEY=
CUSTOM_AI_API_KEY=
ZETRO_REQUEST_TIMEOUT_MS=30000
ZETRO_MAX_TOKENS=700
ZETRO_TEMPERATURE=0.4

# Electron desktop client
# Development frontend URL is optional; packaged builds use bundled local assets.
ELECTRON_DEV_SERVER_URL=http://codexsun.local:6010
ELECTRON_API_BASE_URL=http://codexsun.local:6005
