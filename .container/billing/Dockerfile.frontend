FROM node:24-bookworm-slim AS build

ARG VITE_API_BASE_URL
ARG VITE_PLATFORM_API_BASE_URL
ARG VITE_BILLING_API_BASE_URL
ARG VITE_STORAGE_BASE_URL
ARG VITE_MEDIA_MANAGER_URL

ENV NODE_ENV=production
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_PLATFORM_API_BASE_URL=$VITE_PLATFORM_API_BASE_URL
ENV VITE_BILLING_API_BASE_URL=$VITE_BILLING_API_BASE_URL
ENV VITE_STORAGE_BASE_URL=$VITE_STORAGE_BASE_URL
ENV VITE_MEDIA_MANAGER_URL=$VITE_MEDIA_MANAGER_URL
ENV VITE_REQUIRE_EXTRACTED_SERVICES=true
ENV VITE_REQUIRED_API_SERVICES=platform,billing

WORKDIR /app

COPY . .
RUN rm -rf apps/frontend/public/storage \
  && mkdir -p apps/frontend/public/storage \
  && npm ci \
  && npm run build:frontend

FROM nginx:1.28-alpine AS runtime

COPY .container/billing/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build/frontend /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=3s --start-period=10s --retries=5 \
  CMD wget -qO- http://127.0.0.1/health >/dev/null || exit 1
