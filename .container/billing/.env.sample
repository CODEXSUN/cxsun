# Copy this file to .container/billing/.env and replace every secret.

DB_HOST=mariadb
DB_PORT=3306
DB_NAME=cxsun_master
DB_USER=root
DB_PASSWORD=replace-me

# Platform API and Billing API must use the same JWT secret.
JWT_SECRET=replace-with-a-long-random-secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
QUEUE_ENABLED=true

BILLING_FRONTEND_URL=https://billing.codexsun.com
BILLING_CORS_ORIGINS=https://billing.codexsun.com
VITE_API_BASE_URL=https://platform-api.codexsun.com
VITE_PLATFORM_API_BASE_URL=https://platform-api.codexsun.com
VITE_BILLING_API_BASE_URL=https://billing-api.codexsun.com
VITE_STORAGE_BASE_URL=https://platform-api.codexsun.com
VITE_MEDIA_MANAGER_URL=https://media.codexsun.com

PLATFORM_API_HOST_PORT=6105
BILLING_API_HOST_PORT=6205
BILLING_FRONTEND_HOST_PORT=6010

CXSUN_DOCKER_NETWORK=codexion-network
BILLING_STORAGE_VOLUME=cxmedia-storage

PLATFORM_API_IMAGE=cxsun/platform-api:latest
BILLING_API_IMAGE=cxsun/billing-api:latest
BILLING_FRONTEND_IMAGE=cxsun/billing-frontend:latest
