FROM node:24-bookworm-slim AS build

ENV NODE_ENV=development
WORKDIR /app

COPY . .
RUN npm ci \
  && npm -w @cxsun/platform run build \
  && npm -w apps/billing-api exec tsc -- --project tsconfig.build.json
RUN node .container/billing/create-runtime-package.mjs \
    /runtime \
    apps/billing-api/package.json \
    packages/platform/package.json \
  && cd /runtime \
  && npm install --omit=dev --ignore-scripts

FROM node:24-bookworm-slim AS runtime

ENV NODE_ENV=production
WORKDIR /app

COPY --from=build /runtime/node_modules ./node_modules
COPY --from=build /app/build/billing-api/billing-api/src ./build/billing-api/billing-api/src
COPY --from=build /app/packages/platform/package.json ./node_modules/@cxsun/platform/package.json
COPY --from=build /app/packages/platform/dist ./node_modules/@cxsun/platform/dist
COPY --from=build /app/package.json ./package.json

RUN mkdir -p apps storage

EXPOSE 6205

CMD ["sh", "-c", "export npm_package_version=\"$(node -p \"require('./package.json').version\")\"; exec node build/billing-api/billing-api/src/main.js"]
