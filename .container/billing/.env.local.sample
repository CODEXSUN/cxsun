# Local-only Billing stack defaults.
#
# Copy to .container/billing/.env.local if you want to customize it.
# .container/billing/billing-stack.sh creates this file from the sample when missing.

DB_HOST=mariadb
DB_PORT=3306
DB_NAME=cxsun_master
DB_USER=root
DB_PASSWORD=DbPass1@@

# Platform API and Billing API must use the same JWT secret.
JWT_SECRET=local-billing-development-secret-change-me

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
QUEUE_ENABLED=true

BILLING_FRONTEND_URL=http://localhost:6011
BILLING_CORS_ORIGINS=http://localhost:6011,http://127.0.0.1:6011
VITE_API_BASE_URL=http://localhost:6105
VITE_PLATFORM_API_BASE_URL=http://localhost:6105
VITE_BILLING_API_BASE_URL=http://localhost:6205
VITE_STORAGE_BASE_URL=http://localhost:6105
VITE_MEDIA_MANAGER_URL=http://localhost:6050
BILLING_START_MEDIA=false
BILLING_DB_SETUP=true
BILLING_DB_SETUP_IMAGE=node:24-bookworm-slim
BILLING_DB_SETUP_NPM_CACHE_VOLUME=cxsun-billing-db-setup-npm-cache

SUPER_ADMIN_NAME=SUNDAR
SUPER_ADMIN_EMAIL=sundar@sundar.com
SUPER_ADMIN_PASSWORD=Kalarani1@@
SOFTWARE_ADMIN_NAME=Admin
SOFTWARE_ADMIN_EMAIL=admin@admin.com
SOFTWARE_ADMIN_PASSWORD=Admin@123
TENANT_ADMIN_NAME=ADMIN
TENANT_ADMIN_EMAIL=admin@tenant.com
TENANT_ADMIN_PASSWORD=admin@123
TENANT_PROVISION_TIMEOUT_MS=120000

PLATFORM_API_HOST_PORT=6105
BILLING_API_HOST_PORT=6205
BILLING_FRONTEND_HOST_PORT=6011

CXSUN_DOCKER_NETWORK=codexion-network
BILLING_STORAGE_VOLUME=cxmedia-storage

PLATFORM_API_IMAGE=cxsun/platform-api:local
BILLING_API_IMAGE=cxsun/billing-api:local
BILLING_FRONTEND_IMAGE=cxsun/billing-frontend:local
