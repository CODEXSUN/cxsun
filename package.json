{
  "name": "cxsun",
  "private": true,
  "version": "1.0.131",
  "type": "module",
  "workspaces": [
    "apps/cli",
    "apps/frontend",
    "apps/server",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,web \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "npm -w apps/server run dev",
    "dev:frontend": "npm -w apps/frontend run dev",
    "check": "npm run typecheck:active && npm run build:active",
    "lint": "npm -w apps/server run lint && npm -w apps/frontend run lint && npm -w packages/shared run lint",
    "typecheck:active": "npm -w apps/server run typecheck && npm -w apps/frontend run typecheck && npm -w packages/shared run typecheck",
    "test:tenant-static": "npm -w apps/server run test:tenant-static",
    "test:tenant-isolation": "npm -w apps/server run test:tenant-isolation",
    "build:active": "node apps/cli/build-active.mjs",
    "restart:active": "node apps/cli/restart-active.mjs",
    "build:server": "npm -w apps/server run build",
    "build:frontend": "npm -w apps/frontend run build",
    "db:refresh": "npm -w apps/server run db:refresh --",
    "db:fresh": "npm -w apps/server run db:fresh --",
    "db:migrate": "npm -w apps/server run db:migrate --",
    "db:seed": "npm -w apps/server run db:seed --",
    "db:setup": "npm -w apps/server run db:setup --",
    "db:backup": "node apps/cli/database-backup.mjs backup",
    "db:restore": "node apps/cli/database-backup.mjs restore",
    "hosts:local": "powershell -ExecutionPolicy Bypass -File apps/cli/setup-local-hosts.ps1",
    "hosts:check": "powershell -ExecutionPolicy Bypass -File apps/cli/setup-local-hosts.ps1 -CheckOnly",
    "version:bump": "node apps/cli/version-bump.mjs",
    "github:now": "node apps/cli/github-helper.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.3"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
